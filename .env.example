# Server Configuration
PORT=8080
HOST=0.0.0.0
GIN_MODE=release

# IDLIX Configuration
IDLIX_BASE_URL=https://tv12.idlixku.com/
IDLIX_TIMEOUT=30s
IDLIX_RETRY=3

# JeniusPlay Configuration
JENIUS_BASE_URL=https://jeniusplay.com/
JENIUS_TIMEOUT=30s

# Download Configuration
MAX_CONCURRENT_DOWNLOADS=10
SEGMENT_WORKERS=50
OUTPUT_DIR=./downloads
TEMP_DIR=./tmp
CLEANUP_AFTER=24h

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg
